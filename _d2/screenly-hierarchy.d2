direction: up

product: Product SBOM {
  class: group
  Screenly: {
    class: accent
  }
}

component: Component SBOM(s) {
  class: group
  "JS SBOM": {
    class: accent
  }
  "Python Backend SBOM": {
    class: accent
  }
  "Docker SBOM": {
    class: accent
  }
  "Rust SBOM": {
    class: accent
  }
  "Python Player SBOM": {
    class: accent
  }
  "QT SBOM": {
    class: accent
  }
  "OS SBOM": {
    class: accent
  }
}

# Connections — components attach directly to the product
component."JS SBOM" -> product.Screenly: {
  class: flow-pink
}
component."Python Backend SBOM" -> product.Screenly: {
  class: flow-pink
}
component."Docker SBOM" -> product.Screenly: {
  class: flow-pink
}
component."Rust SBOM" -> product.Screenly: {
  class: flow-pink
}
component."Python Player SBOM" -> product.Screenly: {
  class: flow-pink
}
component."QT SBOM" -> product.Screenly: {
  class: flow-pink
}
component."OS SBOM" -> product.Screenly: {
  class: flow-pink
}
